<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="human_model">
  
  <!-- Load parameters from YAML file -->
  <xacro:arg name="width" default="0.4"/>
  <xacro:arg name="height" default="1.7"/>
  <xacro:arg name="depth" default="0.2"/>
  <xacro:arg name="mass" default="70.0"/>
  <xacro:arg name="color_r" default="0.8"/>
  <xacro:arg name="color_g" default="0.6"/>
  <xacro:arg name="color_b" default="0.5"/>
  
  <!-- Base link (main body) -->
  <link name="base_link">
    <inertial>
      <mass value="$(arg mass)"/>
      <inertia ixx="${(arg mass) * (((arg height)**2 + (arg depth)**2) / 12)}" 
               iyy="${(arg mass) * (((arg width)**2 + (arg depth)**2) / 12)}" 
               izz="${(arg mass) * (((arg width)**2 + (arg height)**2) / 12)}" 
               ixy="0.0" ixz="0.0" iyz="0.0"/>
      <origin xyz="0 0 ${(arg height)/2}" rpy="0 0 0"/>
    </inertial>
    
    <!-- Visual: Rectangle representing human body -->
    <visual>
      <origin xyz="0 0 ${(arg height)/2}" rpy="0 0 0"/>
      <geometry>
        <box size="$(arg width) $(arg depth) $(arg height)"/>
      </geometry>
      <material name="human_skin">
        <color rgba="$(arg color_r) $(arg color_g) $(arg color_b) 1.0"/>
      </material>
    </visual>
    
    <!-- Collision: Same as visual -->
    <collision>
      <origin xyz="0 0 ${(arg height)/2}" rpy="0 0 0"/>
      <geometry>
        <box size="$(arg width) $(arg depth) $(arg height)"/>
      </geometry>
    </collision>
  </link>
  
  <!-- Fixed joint to world for initial placement -->
  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  
  <!-- World link for reference -->
  <link name="world"/>
  
</robot>
